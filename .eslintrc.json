{
  "extends": ["next/core-web-vitals", "plugin:sonarjs/recommended", "plugin:prettier/recommended"],
  "plugins": ["sonarjs", "prettier", "simple-import-sort"],
  "rules": {
    "prettier/prettier": [
      "warn",
      {
        "trailingComma": "none",
        "tabWidth": 2,
        "semi": false,
        "singleQuote": true,
        "arrowParens": "avoid",
        "printWidth": 100
      }
    ],
    "simple-import-sort/imports": "warn",
    "simple-import-sort/exports": "warn"
  }
}
